# ── Public surface whitelist ────────────────────────────────────────────
# This repository publishes only the buildable app plus README, LICENSE,
# notices, and screenshots. Everything else (engineering docs, decisions,
# changelog, the T012 instrumentation subsystem, and internal scripts) is
# kept local / in a private companion repo and must not be pushed here.
# Verify with: git ls-files  and a fresh-clone `./gradlew assembleDebug`.
/*
!/.gitignore
!/README.md
!/LICENSE
!/THIRD_PARTY_NOTICES.md
!/build.gradle
!/settings.gradle
!/gradle.properties
!/gradlew
!/gradlew.bat
!/gradle
!/app
!/assets

# gradle/: wrapper only
/gradle/*
!/gradle/wrapper

# app/: build script, main sources, and JVM unit tests only
/app/*
!/app/build.gradle
!/app/src
/app/src/*
!/app/src/main
!/app/src/test

# never track build outputs or local config
build/
.gradle/
.idea/
local.properties
*.apk
*.aab
.claude/
